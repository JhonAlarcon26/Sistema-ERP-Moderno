@model Sistema_ERP.Models.Cotizacione

<div class="space-y-6">
    
    <div class="flex justify-between items-start border-b border-slate-700/50 pb-4">
        <div>
            <h4 class="text-white font-bold text-lg">Cotización @(Model.NroCorrelativo ?? "#" + Model.IdCotizacion.ToString("D5"))</h4>
            <p class="text-slate-500 text-xs">Fecha: @Model.Fecha?.ToString("dd/MM/yyyy HH:mm")</p>
        </div>
        <div class="text-right">
            <span class="badge @(Model.Estado == "Realizado" ? "badge-green" : (Model.Estado == "Pendiente" ? "badge-orange" : "badge-blue"))">
                <i class="bi @(Model.Estado == "Realizado" ? "bi-check-circle" : (Model.Estado == "Pendiente" ? "bi-clock-history" : "bi-file-earmark-text")) mr-1"></i>
                @Model.Estado?.ToUpper()
            </span>
        </div>
    </div>

    
    <div class="grid grid-cols-2 gap-4">
        <div>
            <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Cliente</p>
            <p class="text-white font-medium">@Model.IdClienteNavigation?.NombreRazonSocial</p>
        </div>
        <div>
            <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">NIT / CI</p>
            <p class="text-slate-300">@(Model.IdClienteNavigation?.NitCi ?? "S/N")</p>
        </div>
    </div>

    
    <div class="overflow-hidden rounded-xl border border-slate-700/50">
        <table class="w-full text-xs text-left">
            <thead class="bg-slate-800/50 text-slate-400">
                <tr>
                    <th class="px-4 py-2 uppercase font-medium">Descripción</th>
                    <th class="px-4 py-2 uppercase font-medium text-center">Cant.</th>
                    <th class="px-4 py-2 uppercase font-medium text-right">P. Unidad</th>
                    <th class="px-4 py-2 uppercase font-medium text-right">Subtotal</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-700/30">
                @foreach (var p in Model.DetalleCotizacionProductos)
                {
                    <tr class="text-slate-300">
                        <td class="px-4 py-2">
                             <div class="flex items-center gap-2">
                                <i class="bi bi-box text-indigo-400"></i>
                                @p.IdProductoNavigation?.NombreProducto
                             </div>
                        </td>
                        <td class="px-4 py-2 text-center">@p.Cantidad</td>
                        <td class="px-4 py-2 text-right">Bs. @p.PrecioVendido.ToString("N2")</td>
                        <td class="px-4 py-2 text-right text-white font-medium">Bs. @((p.Cantidad * p.PrecioVendido).ToString("N2"))</td>
                    </tr>
                }
                @foreach (var s in Model.DetalleCotizacionServicios)
                {
                    <tr class="text-slate-300">
                        <td class="px-4 py-2">
                             <div class="flex items-center gap-2">
                                <i class="bi bi-tools text-amber-400"></i>
                                @s.IdServicioNavigation?.NombreServicio
                             </div>
                        </td>
                        <td class="px-4 py-2 text-center">@s.Cantidad</td>
                        <td class="px-4 py-2 text-right">Bs. @s.PrecioCobrado.ToString("N2")</td>
                        <td class="px-4 py-2 text-right text-white font-medium">Bs. @((s.Cantidad * s.PrecioCobrado).ToString("N2"))</td>
                    </tr>
                }
            </tbody>
            @{
                decimal total = Model.DetalleCotizacionProductos.Sum(p => p.Cantidad * p.PrecioVendido) +
                                Model.DetalleCotizacionServicios.Sum(s => s.Cantidad * s.PrecioCobrado);
            }
            <tfoot class="bg-indigo-600/10">
                <tr class="text-white font-bold">
                    <td colspan="3" class="px-4 py-3 text-right uppercase tracking-wider">Total Final</td>
                    <td class="px-4 py-3 text-right text-indigo-400 text-sm">Bs. @total.ToString("N2")</td>
                </tr>
            </tfoot>
        </table>
    </div>

    
    <div class="flex gap-3 pt-2">
        <button onclick="closeModal('modalDetalle')" class="btn-primary flex-1 justify-center py-2 text-xs">
            Cerrar
        </button>
    </div>
</div>
