@model Sistema_ERP.Models.Cotizacione

<div class="space-y-6 animate-in fade-in zoom-in duration-300">
    <div class="flex items-center justify-between border-b border-slate-700 pb-4">
        <div>
            <h3 class="text-2xl font-black text-white">@(Model.NroCorrelativo ?? "#" + Model.IdCotizacion.ToString("D5"))</h3>
            <p class="text-slate-500 text-xs uppercase tracking-widest font-bold">@Model.TipoOperacion</p>
        </div>
        <div class="text-right">
            <p class="text-white font-bold">@Model.Fecha?.ToString("dd/MM/yyyy")</p>
            <p class="text-slate-500 text-xs">@Model.Fecha?.ToString("HH:mm")</p>
        </div>
    </div>

    <div class="grid grid-cols-2 gap-8 text-sm">
        <div>
            <h4 class="text-slate-500 font-bold uppercase text-[10px] mb-2 tracking-wider">Cliente</h4>
            <p class="text-white font-bold text-lg">@Model.IdClienteNavigation?.NombreRazonSocial</p>
            <p class="text-slate-400">NIT: @(Model.IdClienteNavigation?.NitCi ?? "---")</p>
            <p class="text-slate-400">@Model.IdClienteNavigation?.Direccion</p>
        </div>
        <div class="text-right">
            <div class="flex flex-col items-end">
                @if (Model.Estado == "Realizado") {
                    <span class="badge badge-green inline-flex">PAGADO</span>
                } else if (Model.Estado == "Pendiente") {
                    <span class="badge badge-orange inline-flex">PENDIENTE</span>
                } else {
                    <span class="badge badge-blue inline-flex">COTIZADO</span>
                }
                @if (Model.IdMetodoPagoNavigation != null) {
                    <p class="text-white mt-1 font-medium text-xs"><i class="bi bi-wallet2 text-indigo-400 mr-1"></i> @Model.IdMetodoPagoNavigation.NombreMetodo</p>
                }
            </div>
            </div>
    </div>

    <div class="space-y-2">
        <h4 class="text-slate-500 font-bold uppercase text-[10px] tracking-wider">Detalles</h4>
        <div class="bg-slate-800/50 rounded-xl overflow-hidden">
            <table class="w-full text-xs">
                <thead>
                    <tr class="bg-slate-800 text-slate-400 text-left">
                        <th class="px-4 py-2">Item</th>
                        <th class="px-4 py-2 text-center">Cant</th>
                        <th class="px-4 py-2 text-right">Precio Venta</th>
                        <th class="px-4 py-2 text-right">Subtotal</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-700/50">
                    @foreach(var p in Model.DetalleCotizacionProductos) {
                        <tr class="text-white">
                            <td class="px-4 py-2">@p.IdProductoNavigation?.NombreProducto</td>
                            <td class="px-4 py-2 text-center">@p.Cantidad</td>
                            <td class="px-4 py-2 text-right">@p.PrecioVendido.ToString("N2")</td>
                            <td class="px-4 py-2 text-right">@((p.Cantidad * p.PrecioVendido).ToString("N2"))</td>
                        </tr>
                    }
                    @foreach(var s in Model.DetalleCotizacionServicios) {
                        <tr class="text-white">
                            <td class="px-4 py-2">@s.IdServicioNavigation?.NombreServicio</td>
                            <td class="px-4 py-2 text-center">@s.Cantidad</td>
                            <td class="px-4 py-2 text-right">@s.PrecioCobrado.ToString("N2")</td>
                            <td class="px-4 py-2 text-right">@((s.Cantidad * s.PrecioCobrado).ToString("N2"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="pt-6 border-t border-slate-700 flex flex-col items-end gap-1">
        <div class="flex justify-between w-48 text-slate-400 text-xs">
            <span>Subtotal:</span>
            <span class="text-white">Bs. @((Model.TotalConImpuesto - (Model.MontoImpuesto ?? 0))?.ToString("N2"))</span>
        </div>
        <div class="flex justify-between w-48 text-slate-400 text-xs">
            <span>I.V.A (@Model.PorcentajeImpuesto%):</span>
            <span class="text-white">Bs. @Model.MontoImpuesto?.ToString("N2")</span>
        </div>
        <div class="flex justify-between w-48 text-xl font-black pt-2">
            <span class="text-indigo-400">TOTAL:</span>
            <span class="text-white">Bs. @Model.TotalConImpuesto?.ToString("N2")</span>
        </div>
    </div>

    <div class="flex justify-end pt-6">
        <button onclick="closeModal('modalDetalle')" class="btn-secondary px-8">Cancelar</button>
    </div>
</div>
