@model Sistema_ERP.Models.InventarioServicio
@{ ViewData["Title"] = "Editar Servicio"; }

<div class="max-w-xl mx-auto">
    <div class="flex items-center gap-3 mb-6">
        <a asp-action="Index" class="text-slate-400 hover:text-white transition-colors"><i class="bi bi-arrow-left text-lg"></i></a>
        <div>
            <h1 class="text-xl font-bold text-white">Editar Servicio</h1>
            <p class="text-slate-500 text-sm">Modifica los Datos del servicio</p>
        </div>
    </div>

    <div class="glass-card p-6">
        <form asp-action="EditarServicio" method="post" enctype="multipart/form-data" class="space-y-5">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="IdServicio" />
            <div>
                <label class="form-label">Nombre del Servicio</label>
                <input asp-for="NombreServicio" class="form-input" required placeholder="Nombre del servicio" />
                <span asp-validation-for="NombreServicio" class="text-red-400 text-xs mt-1 block"></span>
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="form-label">Categoría</label>
                    <select asp-for="Categoria" class="form-input select-searchable">
                        <option value="">-- Seleccionar --</option>
                        @if (ViewBag.Categorias != null)
                        {
                            foreach (var cat in ViewBag.Categorias)
                            {
                                <option value="@cat.Nombre">@cat.Nombre</option>
                            }
                        }
                    </select>
                </div>
                <div>
                    <label class="form-label">Precio Venta (Bs.)</label>
                    <input asp-for="PrecioVenta" type="number" step="0.01" class="form-input" />
                    <span asp-validation-for="PrecioVenta" class="text-red-400 text-xs mt-1 block"></span>
                </div>
            </div>
            <div>
                <label class="form-label text-xs uppercase tracking-wider text-slate-300">Imagen del Servicio (Opcional)</label>
                <div class="flex items-center gap-4 mt-1">
                    <div class="w-16 h-16 rounded-xl bg-slate-900/50 border border-slate-700/50 overflow-hidden flex-shrink-0 flex items-center justify-center shadow-inner" style="width: 64px; height: 64px; min-width: 64px; overflow: hidden;">
                        <img id="imgPreviewSrvEdit" src="@(string.IsNullOrEmpty(Model.ImagenUrl) ? "/img/no-image.png" : Model.ImagenUrl)" class="w-full h-full object-cover text-slate-500" style="width: 100%; height: 100%; object-fit: cover;" alt="Preview"/>
                    </div>
                    <div class="flex-1 relative">
                        <label for="inpImagenSrvEdit" class="cursor-pointer flex items-center justify-between w-full px-4 py-3 bg-slate-900/40 hover:bg-slate-800/60 border border-slate-700/50 rounded-xl text-sm font-medium text-slate-300 transition-all focus-within:border-indigo-500 focus-within:ring-1 focus-within:ring-indigo-500">
                            <div class="flex items-center gap-2 overflow-hidden">
                                <i class="bi bi-image text-indigo-400"></i>
                                <span id="txtFileNameSrvEdit" class="truncate text-slate-400">Seleccionar imagen pinchando aquí...</span>
                            </div>
                            <span class="bg-indigo-600/20 text-indigo-300 text-xs px-2 py-1 rounded-md border border-indigo-500/30">Explorar</span>
                        </label>
                        <input type="file" name="imagen" id="inpImagenSrvEdit" accept="image/*" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer hidden" onchange="previewImagenSrvEdit(this, 'imgPreviewSrvEdit', 'txtFileNameSrvEdit')">
                    </div>
                </div>
            </div>
            <div>
                <label class="form-label">Descripción</label>
                <textarea asp-for="Descripcion" class="form-input" rows="3" placeholder="Descripción adicional"></textarea>
            </div>
            <div class="flex gap-3 pt-2">
                <button type="button" onclick="window.history.back()" class="btn-secondary flex-1 justify-center">Cancelar</button>
                <button type="submit" class="btn-primary flex-1 justify-center">Guardar</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function previewImagenSrvEdit(input, imgId, textId) {
            var textElem = document.getElementById(textId);
            if (input.files && input.files[0]) {
                if(textElem) textElem.textContent = input.files[0].name;
                var reader = new FileReader();
                reader.onload = function(e) { document.getElementById(imgId).src = e.target.result; }
                reader.readAsDataURL(input.files[0]);
            } else {
                if(textElem) textElem.textContent = "Seleccionar imagen pinchando aquí...";
                document.getElementById(imgId).src = '@(!string.IsNullOrEmpty(Model.ImagenUrl) ? Model.ImagenUrl : "/img/no-image.png")';
            }
        }
    </script>
}
