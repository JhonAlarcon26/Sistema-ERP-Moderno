@model IEnumerable<Sistema_ERP.Models.Permiso>
@{ ViewData["Title"] = "Permisos"; }

<div class="flex items-center justify-between mb-8">
    <div>
        <h1 class="text-2xl font-bold text-white flex items-center gap-3">
            <span class="w-9 h-9 bg-amber-600/20 rounded-xl flex items-center justify-center">
                <i class="bi bi-key text-amber-400 text-lg"></i>
            </span>
            Permisos
        </h1>
        <p class="text-slate-500 text-sm mt-1">Define los permisos del sistema</p>
    </div>
    <div class="flex items-center gap-3">
        @if (User.HasClaim("Permission", "SincronizarPermisos"))
        {
            <form asp-action="Sincronizar" method="post" onsubmit="return confirm('¿Seguro que deseas sincronizar los permisos base del sistema? Se restaurarán los faltantes y se actualizará el rol Administrador.')">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-secondary !bg-amber-500/10 !text-amber-500 !border-amber-500/20 hover:!bg-amber-500 hover:!text-white">
                    <i class="bi bi-shield-check"></i> Sincronizar Sistema
                </button>
            </form>
        }
        <a asp-action="Crear" class="btn-primary">
            <i class="bi bi-plus-lg"></i> Nuevo Permiso
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="mb-4 p-4 rounded-xl bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm flex items-center gap-3 animate-pulse-subtle">
        <i class="bi bi-check-circle-fill text-lg"></i>
        <span>@TempData["Success"]</span>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="mb-4 p-4 rounded-xl bg-rose-500/10 border border-rose-500/20 text-rose-400 text-sm flex items-center gap-3">
        <i class="bi bi-exclamation-triangle-fill text-lg"></i>
        <span>@TempData["Error"]</span>
    </div>
}
@if (TempData["Info"] != null)
{
    <div class="mb-4 p-4 rounded-xl bg-blue-500/10 border border-blue-500/20 text-blue-400 text-sm flex items-center gap-3">
        <i class="bi bi-info-circle-fill text-lg"></i>
        <span>@TempData["Info"]</span>
    </div>
}

<div class="glass-card p-6">
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6 p-4 bg-slate-800/50 rounded-xl border border-slate-700/50">
        <div>
            <label class="text-[10px] text-slate-400 uppercase font-bold tracking-wider mb-1 block"><i class="bi bi-hash"></i> ID</label>
            <input type="text" id="filtroId" placeholder="Ej. 1..." class="w-full bg-slate-900 border border-slate-700/50 rounded-lg px-3 py-2 text-white text-sm focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 outline-none transition-all">
        </div>
        <div class="lg:col-span-2">
            <label class="text-[10px] text-slate-400 uppercase font-bold tracking-wider mb-1 block"><i class="bi bi-key"></i> Nombre del Permiso</label>
            <input type="text" id="filtroNombre" placeholder="Buscar permiso..." class="w-full bg-slate-900 border border-slate-700/50 rounded-lg px-3 py-2 text-white text-sm focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 outline-none transition-all">
        </div>
        <div class="flex items-end">
            <button type="button" onclick="limpiarFiltros()" class="w-full bg-slate-800 hover:bg-slate-700 text-slate-400 hover:text-white border border-slate-700 px-3 py-2 rounded-lg text-sm transition-all flex items-center justify-center gap-2 group">
                <i class="bi bi-eraser-fill group-hover:rotate-12 transition-transform"></i>
                Limpiar
            </button>
        </div>
    </div>

    <div class="overflow-x-auto">
        <table id="tablaPermisos" class="w-full text-sm text-left">
            <thead>
                <tr class="border-b border-slate-700/50 bg-slate-800/30">
                    <th class="px-5 py-4 text-slate-400 font-semibold uppercase tracking-wider text-xs w-20">ID</th>
                    <th class="px-5 py-4 text-slate-400 font-semibold uppercase tracking-wider text-xs">Permiso</th>
                    <th class="px-5 py-4 text-slate-400 font-semibold uppercase tracking-wider text-xs">Descripción</th>
                    <th class="px-5 py-4 text-slate-400 font-semibold uppercase tracking-wider text-xs text-right w-24">Acciones</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-700/30">
                @foreach (var p in Model)
                {
                    <tr class="hover:bg-slate-800/20 transition-colors group">
                        <td class="px-5 py-4 text-amber-500 font-mono text-xs font-bold">#@p.IdPermiso</td>
                        <td class="px-5 py-4">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-lg bg-amber-500/10 flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
                                    <i class="bi bi-key text-amber-500 text-xs text-shadow-glow"></i>
                                </div>
                                <span class="text-white font-bold font-mono text-xs tracking-tight">@p.NombrePermiso</span>
                            </div>
                        </td>
                        <td class="px-5 py-4">
                            <span class="text-slate-400 text-xs italic">@(string.IsNullOrEmpty(p.Descripcion) ? "Sin descripción" : p.Descripcion)</span>
                        </td>
                        <td class="px-5 py-4 text-right leading-none">
                            <div class="flex items-center justify-end gap-1.5">
                                <a asp-action="Editar" asp-route-id="@p.IdPermiso" class="w-8 h-8 flex items-center justify-center bg-amber-500/10 text-amber-500 hover:bg-amber-500 hover:text-white rounded-lg transition-all" title="Editar">
                                    <i class="bi bi-pencil-square text-xs"></i>
                                </a>
                                <form asp-action="Eliminar" asp-route-id="@p.IdPermiso" method="post" class="inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="w-8 h-8 flex items-center justify-center bg-red-500/10 text-red-500 hover:bg-red-500 hover:text-white rounded-lg transition-all" title="Eliminar">
                                        <i class="bi bi-trash-fill text-xs"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var table = $('#tablaPermisos').DataTable({
                dom: 'rtip',
                language: { url: "https://cdn.datatables.net/plug-ins/1.13.7/i18n/es-ES.json" },
                order: [[0, 'desc']],
                pageLength: 25
            });

            $('#filtroId').on('keyup', function() { table.column(0).search(this.value).draw(); });
            $('#filtroNombre').on('keyup', function() { table.column(1).search(this.value).draw(); });
        });

        function limpiarFiltros() {
            $('#filtroId, #filtroNombre').val('');
            $('#tablaPermisos').DataTable().search('').columns().search('').draw();
        }
    </script>
}
