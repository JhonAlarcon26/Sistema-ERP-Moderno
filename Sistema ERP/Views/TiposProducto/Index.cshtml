@model IEnumerable<Sistema_ERP.Models.TipoProducto>
@{ ViewData["Title"] = "Tipos de Producto"; }

<div class="flex items-center justify-between mb-8">
    <div>
        <h1 class="text-2xl font-bold text-white flex items-center gap-3">
            <span class="w-9 h-9 bg-emerald-600/20 rounded-xl flex items-center justify-center">
                <i class="bi bi-tags text-emerald-400 text-lg"></i>
            </span>
            Tipos de Producto
        </h1>
        <p class="text-slate-500 text-sm mt-1">Categorías de clasificación de productos</p>
    </div>
    <button onclick="document.getElementById('formNuevoTipo').classList.toggle('hidden')" class="btn-primary">
        <i class="bi bi-plus-lg"></i> Nuevo Tipo
    </button>
</div>

@if (TempData["Success"] != null)
{
    <div class="mb-4 p-3 rounded-xl bg-emerald-500/10 border border-emerald-500/30 text-emerald-400 text-sm flex items-center gap-2">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="mb-4 p-3 rounded-xl bg-rose-500/10 border border-rose-500/30 text-rose-400 text-sm flex items-center gap-2">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
    </div>
}


<div id="formNuevoTipo" class="glass-card p-5 mb-6 hidden">
    <form asp-action="Crear" method="post" class="flex items-end gap-4">
        @Html.AntiForgeryToken()
        <div class="w-1/3">
            <label class="form-label text-xs uppercase tracking-wider">Nombre del Tipo</label>
            <input type="text" name="Nombre" class="form-input" required placeholder="Ej: Electrónica, Ropa...">
        </div>
        <div class="flex-1">
            <label class="form-label text-xs uppercase tracking-wider">Descripción</label>
            <input type="text" name="Descripcion" class="form-input" placeholder="Opcional: Detalles breves...">
        </div>
        <button type="submit" class="btn-primary whitespace-nowrap"><i class="bi bi-save"></i> Guardar</button>
        <button type="button" onclick="document.getElementById('formNuevoTipo').classList.add('hidden')" class="btn-secondary whitespace-nowrap">Cancelar</button>
    </form>
</div>

<div class="glass-card p-6">
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6 p-4 bg-slate-800/50 rounded-xl border border-slate-700/50">
        <div>
            <label class="text-[10px] text-slate-400 uppercase font-bold tracking-wider mb-1 block"><i class="bi bi-hash"></i> ID</label>
            <input type="text" id="filtroId" placeholder="Ej. 1..." class="w-full bg-slate-900 border border-slate-700/50 rounded-lg px-3 py-2 text-white text-sm focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 outline-none transition-all">
        </div>
        <div class="lg:col-span-2">
            <label class="text-[10px] text-slate-400 uppercase font-bold tracking-wider mb-1 block"><i class="bi bi-tag"></i> Nombre del Tipo</label>
            <input type="text" id="filtroNombre" placeholder="Buscar categoría..." class="w-full bg-slate-900 border border-slate-700/50 rounded-lg px-3 py-2 text-white text-sm focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 outline-none transition-all">
        </div>
        <div class="flex items-end">
            <button type="button" onclick="limpiarFiltros()" class="w-full bg-slate-800 hover:bg-slate-700 text-slate-400 hover:text-white border border-slate-700 px-3 py-2 rounded-lg text-sm transition-all flex items-center justify-center gap-2 group">
                <i class="bi bi-eraser-fill group-hover:rotate-12 transition-transform"></i>
                Limpiar
            </button>
        </div>
    </div>

    <div class="overflow-x-auto">
        <table id="tablaTipos" class="w-full text-sm text-left">
            <thead>
                <tr class="border-b border-slate-700/50 bg-slate-800/30">
                    <th class="px-5 py-4 text-slate-400 font-semibold uppercase tracking-wider text-xs w-20">ID</th>
                    <th class="px-5 py-4 text-slate-400 font-semibold uppercase tracking-wider text-xs">Categoría</th>
                    <th class="px-5 py-4 text-slate-400 font-semibold uppercase tracking-wider text-xs">Descripción</th>
                    <th class="px-5 py-4 text-slate-400 font-semibold uppercase tracking-wider text-xs text-right w-24">Acciones</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-700/30">
                @foreach (var t in Model)
                {
                    <tr class="hover:bg-slate-800/20 transition-colors group">
                        <td class="px-5 py-4 text-indigo-400 font-mono text-xs">#@t.IdTipoProducto</td>
                        <td class="px-5 py-4">
                            <span class="text-white font-bold block">@t.Nombre</span>
                        </td>
                        <td class="px-5 py-4">
                            <span class="text-slate-400 text-xs italic">@(string.IsNullOrEmpty(t.Descripcion) ? "Sin descripción" : t.Descripcion)</span>
                        </td>
                        <td class="px-5 py-4 text-right">
                            <div class="flex items-center justify-end gap-1.5">
                                <a asp-action="Editar" asp-route-id="@t.IdTipoProducto" class="w-8 h-8 flex items-center justify-center bg-amber-500/10 text-amber-500 hover:bg-amber-500 hover:text-white rounded-lg transition-all" title="Editar">
                                    <i class="bi bi-pencil-square text-xs"></i>
                                </a>
                                <form asp-action="Eliminar" asp-route-id="@t.IdTipoProducto" method="post" class="inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="w-8 h-8 flex items-center justify-center bg-red-500/10 text-red-500 hover:bg-red-500 hover:text-white rounded-lg transition-all" title="Eliminar">
                                        <i class="bi bi-trash-fill text-xs"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var table = $('#tablaTipos').DataTable({
                dom: 'rtip',
                language: { url: "https://cdn.datatables.net/plug-ins/1.13.7/i18n/es-ES.json" },
                order: [[0, 'desc']],
                pageLength: 15
            });


            $('#filtroId').on('input keyup change', function() { 
                table.column(0).search(this.value.trim()).draw(); 
            });
            
            $('#filtroNombre').on('input keyup change', function() { 
                table.column(1).search(this.value.trim()).draw(); 
            });
        });

        function limpiarFiltros() {
            $('#filtroId, #filtroNombre').val('');
            $('#tablaTipos').DataTable().search('').columns().search('').draw();
        }
    </script>
}
