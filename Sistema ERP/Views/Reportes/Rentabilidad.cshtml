@model IEnumerable<Sistema_ERP.Models.ReporteRentabilidadViewModel>
@{ ViewData["Title"] = "Reporte de Rentabilidad"; }

<div class="no-print flex items-center justify-between mb-8">
    <div>
        <h1 class="text-2xl font-bold text-white flex items-center gap-3">
            <span class="w-9 h-9 bg-emerald-600/20 rounded-xl flex items-center justify-center">
                <i class="bi bi-graph-up-arrow text-emerald-400 text-lg"></i>
            </span>
            Rentabilidad por Producto
        </h1>
        <p class="text-slate-500 text-sm mt-1">Análisis detallado de márgenes de ganancia</p>
    </div>
    <div class="flex gap-3">
         <button onclick="imprimirReporte()" class="btn-primary">
            <i class="bi bi-printer"></i> Imprimir Reporte
        </button>
    </div>
</div>

<script>
    function imprimirReporte() {
        const fechaInicio = document.querySelector('input[name="fechaInicio"]').value;
        const fechaFin = document.querySelector('input[name="fechaFin"]').value;
        window.open(`/Reportes/ImprimirRentabilidad?fechaInicio=${fechaInicio}&fechaFin=${fechaFin}`, '_blank');
    }
</script>


<div class="no-print glass-card p-6 mb-8 border-l-4 border-emerald-500">
    <form method="get" action="/Reportes/Rentabilidad" class="flex flex-wrap items-end gap-6">
        <div class="flex-1 min-w-[200px]">
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Fecha Inicio</label>
            <input type="Date" name="fechaInicio" value="@ViewBag.FechaInicio" class="form-input" />
        </div>
        <div class="flex-1 min-w-[200px]">
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Fecha Fin</label>
            <input type="Date" name="fechaFin" value="@ViewBag.FechaFin" class="form-input" />
        </div>
        <button type="submit" class="btn-secondary h-[42px] px-6">
            <i class="bi bi-filter mr-2"></i> Filtrar Datos
        </button>
        <a href="/Reportes/Rentabilidad" class="text-slate-500 hover:text-white text-sm pb-2 transition-colors">Limpiar Filtros</a>
    </form>
</div>

<div class="glass-card overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-slate-700/50 bg-slate-800/20">
                    <th class="text-left px-5 py-4 text-slate-400 font-medium text-xs uppercase tracking-wider">Producto</th>
                    <th class="text-right px-5 py-4 text-slate-400 font-medium text-xs uppercase tracking-wider">P. Venta (c/f)</th>
                    <th class="text-right px-5 py-4 text-slate-400 font-medium text-xs uppercase tracking-wider">Costo Prom.</th>
                    <th class="text-right px-5 py-4 text-slate-400 font-medium text-xs uppercase tracking-wider">Utilidad</th>
                    <th class="text-center px-5 py-4 text-slate-400 font-medium text-xs uppercase tracking-wider">Margen %</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-700/30">
                @foreach (var item in Model)
                {
                    var ganancia = item.PrecioVentaConFactura - item.CostoPromedio;
                    var margen = item.PrecioVentaConFactura > 0 ? (ganancia / item.PrecioVentaConFactura) * 100 : 0;
                    
                    <tr class="hover:bg-slate-700/10 transition-colors">
                        <td class="px-5 py-4">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-lg bg-emerald-500/10 flex items-center justify-center flex-shrink-0">
                                    <i class="bi bi-tag text-emerald-400 text-xs"></i>
                                </div>
                                <span class="text-white font-medium">@item.NombreProducto</span>
                            </div>
                        </td>
                        <td class="px-5 py-4 text-right text-white font-mono">Bs. @item.PrecioVentaConFactura.ToString("N2")</td>
                        <td class="px-5 py-4 text-right text-amber-500 font-mono">Bs. @item.CostoPromedio.ToString("N2")</td>
                        <td class="px-5 py-4 text-right text-emerald-400 font-bold font-mono">Bs. @ganancia.ToString("N2")</td>
                        <td class="px-5 py-4 text-center">
                            @if (margen >= 30)
                            {
                                <span class="badge badge-green">@margen.ToString("N1")%</span>
                            }
                            else if (margen >= 10)
                            {
                                <span class="badge badge-amber">@margen.ToString("N1")%</span>
                            }
                            else
                            {
                                <span class="badge badge-red">@margen.ToString("N1")%</span>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="px-5 py-14 text-center text-slate-500">
                        <i class="bi bi-bar-chart text-4xl block mb-3 opacity-30"></i>
                        No hay Datos en el rango seleccionado
                    </td></tr>
                }
            </tbody>
        </table>
    </div>
</div>


