@model dynamic
@{ ViewData["Title"] = "Nueva Compra"; }

<div class="mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
    <div>
        <h1 class="text-2xl font-bold text-white tracking-tight">Nueva Compra / Ingreso</h1>
        <p class="text-sm text-slate-400 mt-1">Registra la entrada de stock a tu inventario</p>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    
    <div class="lg:col-span-1 space-y-6">
        
        <div class="glass-card p-5">
            <h2 class="text-sm font-bold text-indigo-300 uppercase tracking-wider mb-4 flex items-center gap-2">
                <i class="bi bi-building"></i> 1. Proveedor
            </h2>
            <div class="space-y-4">
                <div class="relative group">
                    <label class="form-label text-xs text-slate-400 uppercase">Seleccionar Proveedor</label>
                    <select id="selProveedor" class="form-input text-sm py-2 bg-slate-900 border-slate-700 disabled:opacity-50" onchange="actualizarNitCiProveedor(this)" required>
                        <option value="" disabled selected>-- Seleccione un Proveedor --</option>
                        @if (ViewBag.Proveedores != null)
                        {
                            foreach (var p in (IEnumerable<dynamic>)ViewBag.Proveedores)
                            {
                                <option value="@p.Value" data-nitci="@p.NitCi">@p.Text</option>
                            }
                        }
                    </select>
                </div>
                <div class="relative group">
                    <label class="form-label text-xs text-slate-500 uppercase tracking-wider">NIT / CI del Proveedor</label>
                    <input type="text" id="txtNitCi" class="form-input text-sm py-2 bg-slate-900/50 border-slate-800 text-slate-500 cursor-not-allowed" readonly placeholder="Automático" tabindex="-1">
                </div>

                <div class="relative group mt-4">
                    <label class="form-label text-xs text-indigo-400 uppercase font-bold tracking-wider">3. Método de Pago</label>
                    <select id="selMetodoPago" class="form-input text-sm py-2 bg-slate-900 border-indigo-500/30">
                        <option value="" disabled selected>-- Seleccione Tipo de Pago --</option>
                        @if (ViewBag.MetodosPago != null)
                        {
                            foreach (var m in (IEnumerable<Sistema_ERP.Models.MetodoPago>)ViewBag.MetodosPago)
                            {
                                <option value="@m.IdMetodo">@m.NombreMetodo</option>
                            }
                        }
                    </select>
                </div>
            </div>
        </div>

        
        <div class="glass-card p-5 border-t-4 border-indigo-500/50">
            <h2 class="text-sm font-bold text-emerald-400 uppercase tracking-wider mb-4 flex items-center gap-2">
                <i class="bi bi-cart-plus"></i> 2. Agregar Producto
            </h2>
            <div class="space-y-4">
                <div class="relative group">
                    <label class="form-label text-xs uppercase tracking-wider">Buscar Producto</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="bi bi-search text-slate-500"></i>
                        </div>
                        <input type="text" id="txtBuscarProd" class="form-input text-sm py-2 pl-9 bg-slate-900 border-slate-700" placeholder="Escribe el nombre..." autocomplete="off">
                    </div>
                    
                    <div id="listaResultados" class="absolute z-50 mt-1 w-full bg-slate-800 border border-slate-700 rounded-lg shadow-xl hidden max-h-48 overflow-y-auto hidden-scrollbar">
                        
                    </div>
                </div>

                <div id="productoSeleccionadoArea" class="hidden space-y-1">
                    <div class="p-2 bg-indigo-900/20 border border-indigo-500/30 rounded-lg group/item relative">
                        <div class="flex justify-between items-start">
                            <div>
                                <p class="text-xs text-indigo-400 font-bold uppercase tracking-widest leading-none mb-1">Producto Seleccionado</p>
                                <p id="lblNombreSel" class="text-xs text-white font-medium truncate"></p>
                                <p id="lblCatSel" class="text-[10px] text-slate-400 truncate mt-0.5"></p>
                            </div>
                            
                            <button type="button" onclick="event.stopPropagation(); limpiarSeleccionProducto()" class="text-slate-500 hover:text-red-400 transition-colors p-1" title="Quitar producto">
                                <i class="bi bi-x-circle-fill text-lg"></i>
                            </button>
                        </div>
                    </div>
                    <input type="hidden" id="hdnProdId">
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div class="relative group">
                        <label class="form-label text-xs uppercase text-emerald-400 font-bold">Costo Compra (Bs)</label>
                        <input type="number" id="numCosto" class="form-input text-sm py-2 bg-slate-900 border-emerald-500/20 focus:border-emerald-500" step="0.01" min="0" placeholder="0.00">
                    </div>
                    <div class="relative group">
                        <label class="form-label text-xs uppercase font-bold text-slate-400">Cantidad</label>
                        <input type="number" id="numCant" class="form-input text-sm py-2 bg-slate-900 border-slate-700" step="1" min="1" placeholder="1">
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div class="relative group">
                        <label class="form-label text-xs uppercase text-indigo-400 font-bold">P. Referencia (Bs)</label>
                        <input type="number" id="numRef" class="form-input text-sm py-2 bg-slate-900 border-indigo-500/20 focus:border-indigo-500" step="0.01" min="0" placeholder="0.00">
                    </div>
                    <div class="relative group">
                        <label class="form-label text-xs uppercase text-amber-400 font-bold">P. Venta (Bs)</label>
                        <input type="number" id="numVenta" class="form-input text-sm py-2 bg-slate-900 border-amber-500/20 focus:border-amber-500" step="0.01" min="0" placeholder="0.00">
                    </div>
                </div>

                <button type="button" onclick="agregarAlCarrito()" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white py-2.5 rounded-xl font-medium transition-all shadow-lg shadow-emerald-900/40 flex items-center justify-center gap-2 mt-2">
                    <i class="bi bi-plus-circle"></i> Añadir a Lista
                </button>
            </div>
        </div>
    </div>

    
    <div class="lg:col-span-2 flex flex-col space-y-6">
        <div class="glass-card p-0 flex-1 flex flex-col min-h-[400px]">
            <div class="p-5 border-b border-slate-800/50 flex justify-between items-center">
                <h2 class="text-sm font-bold text-white uppercase tracking-wider flex items-center gap-2">
                    <i class="bi bi-list-check text-indigo-400 text-lg"></i> 3. Detalles de Compra
                </h2>
                <span id="badgeItems" class="bg-indigo-500/20 text-indigo-300 text-xs px-2.5 py-1 rounded-full font-medium border border-indigo-500/30">
                    0 ítems
                </span>
            </div>
            
            <div class="flex-1 overflow-auto p-5">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="text-xs uppercase tracking-wider text-slate-400 border-b border-slate-800">
                            <th class="pb-3 font-medium">Producto</th>
                            <th class="pb-3 font-medium text-center w-24">Cantidad</th>
                            <th class="pb-3 font-medium text-right w-32 whitespace-nowrap">Costo Compra</th>
                            <th class="pb-3 font-medium text-right w-32">Subtotal</th>
                            <th class="pb-3 font-medium text-center w-16">Acción</th>
                        </tr>
                    </thead>
                    <tbody id="tblCarrito" class="text-sm divide-y divide-slate-800/50">
                        <tr id="rowVacio">
                            <td colspan="5" class="py-12 text-center text-slate-500">
                                <i class="bi bi-cart-x text-4xl mb-3 block opacity-20"></i>
                                Aún no agregaste productos a esta compra.
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            
            <div class="bg-slate-900/80 p-5 rounded-b-2xl border-t border-slate-800">
                <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
                    <div class="text-slate-400">
                        <p class="text-xs uppercase tracking-wider">Total a Pagar</p>
                        <p class="text-3xl font-bold text-emerald-400" id="lblTotalGral">Bs. 0.00</p>
                    </div>
                    <div class="flex items-center gap-3">
                        <a asp-action="Index" class="bg-slate-800 hover:bg-slate-700 text-slate-400 hover:text-white px-8 py-3 rounded-xl font-bold transition-all border border-slate-700 flex items-center justify-center gap-3 shadow-sm">
                            <i class="bi bi-x-lg"></i> Cancelar
                        </a>
                        <button type="button" id="btnConfirmar" onclick="confirmarCompra()" disabled class="bg-indigo-600 hover:bg-indigo-500 disabled:opacity-50 disabled:cursor-not-allowed text-white px-8 py-3 rounded-xl font-bold transition-all shadow-lg shadow-indigo-900/50 flex items-center justify-center gap-3">
                            <i class="bi bi-save text-lg"></i> Guardar
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>

        const productosDB = @Html.Raw(ViewBag.ProductosJson ?? "[]");
        let carrito = [];


        const txtBuscarProd = document.getElementById('txtBuscarProd');
        const listaResultados = document.getElementById('listaResultados');
        const productoSeleccionadoArea = document.getElementById('productoSeleccionadoArea');
        const hdnProdId = document.getElementById('hdnProdId');
        const lblNombreSel = document.getElementById('lblNombreSel');
        const lblCatSel = document.getElementById('lblCatSel');
        const numCosto = document.getElementById('numCosto');
        const numCant = document.getElementById('numCant');


        function buscarSugerencias(q = "") {
            const query = q.toLowerCase().trim();
            listaResultados.innerHTML = '';
            
            let filtrados = [];
            if (query.length < 1) {

                filtrados = productosDB.slice(0, 20);
            } else {
                filtrados = productosDB.filter(p => 
                    p.nombre.toLowerCase().includes(query) || 
                    (p.categoria && p.categoria.toLowerCase().includes(query))
                );
            }
            
            if (filtrados.length === 0) {
                listaResultados.innerHTML = '<div class="p-3 text-xs text-slate-500 text-center">No catalogado. <a href="/Productos" class="text-indigo-400 underline">Ir al Catálogo</a></div>';
            } else {
                filtrados.slice(0, 20).forEach(p => {
                    const div = document.createElement('div');
                    div.className = 'p-3 hover:bg-indigo-600/20 cursor-pointer border-b border-slate-700/50 last:border-0 transition-colors flex justify-between items-center';
                    div.innerHTML = `
                        <div>
                            <p class="text-sm text-white font-medium">${p.nombre}</p>
                            <p class="text-xs text-slate-400">${p.categoria || 'Sin tipo'} | Stock: <span class="${p.stock > 0 ? 'text-emerald-400' : 'text-red-400'}">${p.stock}</span></p>
                        </div>
                        <i class="bi bi-plus-circle text-slate-600 group-hover:text-indigo-400"></i>
                    `;
                    div.onclick = () => seleccionarProducto(p);
                    listaResultados.appendChild(div);
                });
            }
            listaResultados.classList.remove('hidden');
        }


        txtBuscarProd.addEventListener('input', e => buscarSugerencias(e.target.value));
        txtBuscarProd.addEventListener('focus', e => buscarSugerencias(e.target.value));


        document.addEventListener('click', (e) => {
            if (!txtBuscarProd.contains(e.target) && !listaResultados.contains(e.target)) {
                listaResultados.classList.add('hidden');
            }
        });

        function seleccionarProducto(p) {
            hdnProdId.value = p.id;
            lblNombreSel.textContent = p.nombre;
            document.getElementById('lblCatSel').textContent = p.categoria || 'Sin tipo definido';
            
            txtBuscarProd.value = '';
            listaResultados.classList.add('hidden');
            productoSeleccionadoArea.classList.remove('hidden');
            
            numCant.value = 1;
            numCosto.value = p.precioCompra || ''; 
            document.getElementById('numRef').value = p.precioRef || '';
            document.getElementById('numVenta').value = p.precioVenta || '';
            
            numCosto.focus();
        }

        function limpiarSeleccionProducto() {
            productoSeleccionadoArea.classList.add('hidden');
            hdnProdId.value = '';
            numCant.value = '';
            numCosto.value = '';
            document.getElementById('numRef').value = '';
            document.getElementById('numVenta').value = '';
            txtBuscarProd.value = '';
            setTimeout(() => {
                txtBuscarProd.focus();
                buscarSugerencias('');
            }, 50);
        }

        function agregarAlCarrito() {
            const id = parseInt(hdnProdId.value);
            const cant = parseFloat(numCant.value);
            const costo = parseFloat(numCosto.value);
            const ref = parseFloat(document.getElementById('numRef').value) || 0;
            const venta = parseFloat(document.getElementById('numVenta').value) || 0;

            if (!id || isNaN(cant) || cant <= 0 || isNaN(costo) || costo < 0) {
                alert("Por favor, selecciona un producto e ingresa valores válidos para cantidad y costo compra.");
                return;
            }


            const prodIndex = carrito.findIndex(c => c.idProducto === id);
            if (prodIndex >= 0) {
                carrito[prodIndex].cantidad += cant;
                carrito[prodIndex].costoUnitario = costo; 
                carrito[prodIndex].precioRef = ref;
                carrito[prodIndex].precioVenta = venta;
            } else {
                carrito.push({
                    idProducto: id,
                    nombre: lblNombreSel.textContent,
                    cat: document.getElementById('lblCatSel').textContent,
                    cantidad: cant,
                    costoUnitario: costo,
                    precioRef: ref,
                    precioVenta: venta
                });
            }


            limpiarSeleccionProducto();

            renderCarrito();
        }

        function renderCarrito() {
            const tbl = document.getElementById('tblCarrito');
            const rowVacio = document.getElementById('rowVacio');
            const bBadge = document.getElementById('badgeItems');
            const lTotal = document.getElementById('lblTotalGral');
            const btnConf = document.getElementById('btnConfirmar');

            if (carrito.length === 0) {
                tbl.querySelectorAll('tr:not(#rowVacio)').forEach(tr => tr.remove());
                if (rowVacio) {
                    rowVacio.classList.remove('hidden');
                    if (!tbl.contains(rowVacio)) tbl.appendChild(rowVacio);
                }
                bBadge.textContent = '0 ítems';
                lTotal.textContent = 'Bs. 0.00';
                btnConf.disabled = true;
                return;
            }

            if (rowVacio) {
                rowVacio.classList.add('hidden');
            }

            tbl.querySelectorAll('tr:not(#rowVacio)').forEach(tr => tr.remove());

            let total = 0;
            let sumCant = 0;

            carrito.forEach((item, index) => {
                const subtotal = item.cantidad * item.costoUnitario;
                total += subtotal;
                sumCant += item.cantidad;

                const tr = document.createElement('tr');
                tr.className = 'hover:bg-slate-800/30 transition-colors group';
                tr.innerHTML = `
                    <td class="py-3 pr-4">
                        <p class="text-white font-medium">${item.nombre}</p>
                        <p class="text-xs text-slate-500">${item.cat}</p>
                    </td>
                    <td class="py-3 text-center">
                        <span class="bg-slate-800 text-slate-300 px-2 py-1 rounded text-xs font-mono">${item.cantidad}</span>
                    </td>
                    <td class="py-3 text-right font-mono text-slate-400">
                        ${item.costoUnitario.toFixed(2)}
                    </td>
                    <td class="py-3 text-right font-mono text-white font-medium">
                        ${subtotal.toFixed(2)}
                    </td>
                    <td class="py-3 text-center">
                        <div class="flex justify-center">
                            <button type="button" onclick="quitarDeCarrito(${index})" class="w-8 h-8 rounded-lg bg-red-500/10 text-red-400 hover:bg-red-500 hover:text-white transition-all flex items-center justify-center">
                                <i class="bi bi-trash-fill text-xs"></i>
                            </button>
                        </div>
                    </td>
                `;
                tbl.appendChild(tr);
            });

            bBadge.textContent = sumCant + ' unds. / ' + carrito.length + ' prods.';
            lTotal.textContent = 'Bs. ' + total.toFixed(2);
            btnConf.disabled = false;
        }

        function quitarDeCarrito(index) {
            carrito.splice(index, 1);
            renderCarrito();
        }

        function actualizarNitCiProveedor(sel) {
            const opt = sel.options[sel.selectedIndex];
            document.getElementById('txtNitCi').value = opt ? (opt.getAttribute('data-nitci') || '') : '';
        }

        function confirmarCompra() {
            if (carrito.length === 0) return;

            const btnConf = document.getElementById('btnConfirmar');
            const originalHtml = btnConf.innerHTML;
            btnConf.disabled = true;
            btnConf.innerHTML = '<i class="bi bi-hourglass-split animate-spin text-lg"></i>';
            
            const idProv = document.getElementById('selProveedor').value;
            if (!idProv) {
                alert("Debes seleccionar un proveedor obligatoriamente.");
                btnConf.disabled = false;
                btnConf.innerHTML = originalHtml;
                return;
            }

            const idMetodo = document.getElementById('selMetodoPago').value;
            if (!idMetodo) {
                alert("Debes seleccionar un tipo de pago obligatoriamente.");
                btnConf.disabled = false;
                btnConf.innerHTML = originalHtml;
                return;
            }

            const payload = {
                IdProveedor: idProv,
                IdMetodoPago: idMetodo,
                Detalles: carrito.map(c => ({
                    IdProducto: c.idProducto,
                    Cantidad: c.cantidad,
                    CostoUnitario: c.costoUnitario,
                    PrecioRef: c.precioRef,
                    PrecioVenta: c.precioVenta
                }))
            };

            fetch('@Url.Action("ConfirmarCompra", "Compras")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(payload)
            })
            .then(r => {
                if(r.ok) return r.json();
                throw new Error("Error en servidor");
            })
            .then(Data => {
                if (Data.success) {
                    window.location.href = "@Url.Action("Index", "Compras")"; 
                } else {
                    alert("Ocurrió un error.");
                    btnConf.disabled = false;
                    btnConf.innerHTML = originalHtml;
                }
            })
            .catch(err => {
                console.error(err);
                alert("Hubo un error al confirmar la compra.");
                btnConf.disabled = false;
                btnConf.innerHTML = originalHtml;
            });
        }
    </script>
}
